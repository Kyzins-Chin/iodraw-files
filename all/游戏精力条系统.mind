{"root":{"data":{"text":"游戏精力条系统"},"children":[{"data":{"text":"精力条的定义","layout":null},"children":[{"data":{"text":"表示角色或单位在游戏中的可用行动次数或持续时间的量表","layout":null},"children":[]}]},{"data":{"text":"精力条的作用","layout":null},"children":[{"data":{"text":"限制玩家的连续行动","layout":null},"children":[]},{"data":{"text":"增加游戏的策略深度","layout":null},"children":[]},{"data":{"text":"营造紧张感和挑战性","layout":null},"children":[]}]},{"data":{"text":"精力条的类型","layout":null},"children":[{"data":{"text":"瞬时消耗型","layout":null},"children":[{"data":{"text":"每次行动消耗固定或浮动精力值，休息或特定方式回复","layout":null},"children":[]}]},{"data":{"text":"持续消耗型","layout":null},"children":[{"data":{"text":"行动过程中持续消耗精力，停止行动或特定方式回复","layout":null},"children":[]}]},{"data":{"text":"复合型","layout":null},"children":[{"data":{"text":"结合瞬时和持续消耗，如冲刺和攻击消耗方式不同","layout":null},"children":[]}]}]},{"data":{"text":"精力条的运作机制","layout":null},"children":[{"data":{"text":"精力消耗","layout":null},"children":[{"data":{"text":"基础动作（奔跑、冲刺、格挡）","layout":null},"children":[]},{"data":{"text":"特殊技能（重击、法术、必杀技）","layout":null},"children":[]},{"data":{"text":"环境互动（攀爬、游泳）","layout":null},"children":[]}]},{"data":{"text":"精力回复","layout":null},"children":[{"data":{"text":"自动回复（站立不动、行走）","layout":null},"children":[]},{"data":{"text":"道具回复（食物、药剂）","layout":null},"children":[]},{"data":{"text":"技能回复（特定技能、队友协助）","layout":null},"children":[]},{"data":{"text":"时间流逝（脱战状态）","layout":null},"children":[]}]}]},{"data":{"text":"精力条的设计考量","layout":null},"children":[{"data":{"text":"回复速度与消耗速度的平衡","layout":null},"children":[]},{"data":{"text":"精力上限与等级/装备的关联","layout":null},"children":[]},{"data":{"text":"精力条在不同游戏类型中的应用（RPG、动作游戏、策略游戏）","layout":null},"children":[]},{"data":{"text":"玩家体验与操作手感的影响","layout":null},"children":[]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}